# ─────────────────────────────────────────────────────────────
# Voxelith environment
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Unsplash Access Key — used ONLY at build time by scripts/fetch-images.mjs
# to download landing imagery into public/media/. Never bundled or exposed.
# Get one at: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
